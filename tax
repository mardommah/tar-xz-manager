#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"
APP_NAME="tax"
INSTALL_DIR="/usr/local/bin"
DESKTOP_DIR="$HOME/.local/share/applications"
ICON_DIR="$HOME/.local/share/icons"
REGISTRY_DIR="$HOME/.local/share/tax-installer"
TMP_DIR=""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { echo -e "${BLUE}[info]${NC} $*"; }
log_ok()    { echo -e "${GREEN}[  ok]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[warn]${NC} $*"; }
log_err()   { echo -e "${RED}[ err]${NC} $*"; }
log_step()  { echo -e "${CYAN}[step]${NC} ${BOLD}$*${NC}"; }

cleanup() {
    if [[ -n "$TMP_DIR" && -d "$TMP_DIR" ]]; then
        rm -rf "$TMP_DIR"
    fi
}
trap cleanup EXIT

usage() {
    cat <<EOF
${BOLD}tax${NC} v${VERSION} — practical tar.xz/gz installer for Linux

${BOLD}USAGE:${NC}
    tax install <archive>    Install application from tar.xz/gz archive
    tax list                 List installed applications
    tax uninstall <name>     Uninstall an application
    tax info <name>          Show info about installed application
    tax help                 Show this help

${BOLD}EXAMPLES:${NC}
    tax install neovim-0.10.tar.xz
    tax install firefox-130.0.tar.xz --name firefox
    tax install app.tar.gz --bin-path bin/app --icon icon.png
    tax uninstall neovim

${BOLD}OPTIONS:${NC}
    --name <name>        Override application name
    --bin-path <path>    Specify binary path inside archive (relative)
    --icon <path>        Specify icon path inside archive (relative)
    --no-desktop         Skip .desktop file creation
    --system             Install to /usr/local instead of user dirs (needs sudo)
EOF
}

# Ensure registry directory exists
ensure_registry() {
    mkdir -p "$REGISTRY_DIR"
}

# Extract archive to temp directory and return the path
extract_archive() {
    local archive="$1"
    TMP_DIR=$(mktemp -d /tmp/tax-installer.XXXXXX)

    log_step "Extracting archive..."

    case "$archive" in
        *.tar.xz|*.txz)
            tar xf "$archive" -C "$TMP_DIR" 2>/dev/null || {
                log_err "Failed to extract. Is this a valid tar.xz file?"
                exit 1
            }
            ;;
        *.tar.gz|*.tgz)
            tar xzf "$archive" -C "$TMP_DIR" 2>/dev/null || {
                log_err "Failed to extract. Is this a valid tar.gz file?"
                exit 1
            }
            ;;
        *.tar.bz2|*.tbz2)
            tar xjf "$archive" -C "$TMP_DIR" 2>/dev/null || {
                log_err "Failed to extract. Is this a valid tar.bz2 file?"
                exit 1
            }
            ;;
        *.tar.zst|*.tzst)
            tar --zstd -xf "$archive" -C "$TMP_DIR" 2>/dev/null || {
                log_err "Failed to extract. Is this a valid tar.zst file?"
                exit 1
            }
            ;;
        *)
            log_err "Unsupported archive format: $archive"
            log_info "Supported: .tar.xz, .tar.gz, .tar.bz2, .tar.zst"
            exit 1
            ;;
    esac

    # If archive extracted into a single directory, use that as root
    local items=("$TMP_DIR"/*)
    if [[ ${#items[@]} -eq 1 && -d "${items[0]}" ]]; then
        echo "${items[0]}"
    else
        echo "$TMP_DIR"
    fi
}

# Detect what kind of application is in the extracted directory
detect_app_type() {
    local dir="$1"

    # Check for AppImage
    local appimage
    appimage=$(find "$dir" -maxdepth 2 -name "*.AppImage" -type f 2>/dev/null | head -1)
    if [[ -n "$appimage" ]]; then
        echo "appimage:$appimage"
        return
    fi

    # Check for pre-built binary in bin/ or root
    for bin_dir in "$dir/bin" "$dir/usr/bin" "$dir/usr/local/bin" "$dir"; do
        if [[ -d "$bin_dir" || "$bin_dir" == "$dir" ]]; then
            local bins
            bins=$(find "$bin_dir" -maxdepth 1 -type f -executable 2>/dev/null | head -5)
            if [[ -n "$bins" ]]; then
                echo "binary:$bin_dir"
                return
            fi
        fi
    done

    # Check for Makefile / CMakeLists / configure (source code)
    if [[ -f "$dir/Makefile" || -f "$dir/makefile" ]]; then
        echo "make:$dir"
        return
    fi
    if [[ -f "$dir/CMakeLists.txt" ]]; then
        echo "cmake:$dir"
        return
    fi
    if [[ -f "$dir/configure" ]]; then
        echo "configure:$dir"
        return
    fi
    if [[ -f "$dir/meson.build" ]]; then
        echo "meson:$dir"
        return
    fi

    # Check for any executable files recursively
    local any_exec
    any_exec=$(find "$dir" -type f -executable 2>/dev/null | head -1)
    if [[ -n "$any_exec" ]]; then
        echo "executable:$any_exec"
        return
    fi

    echo "unknown:"
}

# Find icon in extracted directory
find_icon() {
    local dir="$1"
    local name="$2"

    # Common icon locations
    for pattern in \
        "$dir"/*.png "$dir"/*.svg \
        "$dir"/icons/*.png "$dir"/icons/*.svg \
        "$dir"/share/icons/**/*.png \
        "$dir"/usr/share/icons/**/*.png \
        "$dir"/data/*.png "$dir"/data/*.svg \
        "$dir"/**/"$name".png "$dir"/**/"$name".svg; do
        local found
        found=$(compgen -G "$pattern" 2>/dev/null | head -1) || true
        if [[ -n "$found" ]]; then
            echo "$found"
            return
        fi
    done

    echo ""
}

# Find .desktop file in extracted directory
find_desktop_file() {
    local dir="$1"
    find "$dir" -maxdepth 3 -name "*.desktop" -type f 2>/dev/null | head -1
}

# Interactive binary selector
select_binary() {
    local dir="$1"
    local bins=()

    while IFS= read -r f; do
        bins+=("$f")
    done < <(find "$dir" -type f -executable 2>/dev/null | sort)

    if [[ ${#bins[@]} -eq 0 ]]; then
        log_err "No executable files found"
        exit 1
    fi

    if [[ ${#bins[@]} -eq 1 ]]; then
        echo "${bins[0]}"
        return
    fi

    echo ""
    log_info "Multiple executables found. Select which to install:"
    echo ""
    local i=1
    for b in "${bins[@]}"; do
        local rel="${b#"$dir"/}"
        local size
        size=$(du -h "$b" 2>/dev/null | cut -f1)
        printf "  ${CYAN}%2d${NC}) %-40s %s\n" "$i" "$rel" "$size"
        ((i++))
    done
    echo ""

    local choice
    while true; do
        read -rp "  Select [1-${#bins[@]}, or 'a' for all]: " choice
        if [[ "$choice" == "a" ]]; then
            printf '%s\n' "${bins[@]}"
            return
        fi
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#bins[@]} )); then
            echo "${bins[$((choice-1))]}"
            return
        fi
        log_warn "Invalid selection. Try again."
    done
}

# Install binary files
install_binaries() {
    local extract_dir="$1"
    local app_name="$2"
    local bin_path="$3"
    local use_sudo="$4"
    local installed_bins=()
    local sudo_cmd=""

    [[ "$use_sudo" == "true" ]] && sudo_cmd="sudo"

    if [[ -n "$bin_path" ]]; then
        # User specified binary path
        local full_path="$extract_dir/$bin_path"
        if [[ ! -f "$full_path" ]]; then
            log_err "Binary not found: $bin_path"
            exit 1
        fi
        local bin_name
        bin_name=$(basename "$full_path")
        $sudo_cmd install -Dm755 "$full_path" "$INSTALL_DIR/$bin_name"
        installed_bins+=("$INSTALL_DIR/$bin_name")
        log_ok "Installed: $INSTALL_DIR/$bin_name"
    else
        # Auto-detect or select
        local selected
        selected=$(select_binary "$extract_dir")

        while IFS= read -r bin; do
            [[ -z "$bin" ]] && continue
            local bin_name
            bin_name=$(basename "$bin")
            $sudo_cmd install -Dm755 "$bin" "$INSTALL_DIR/$bin_name"
            installed_bins+=("$INSTALL_DIR/$bin_name")
            log_ok "Installed: $INSTALL_DIR/$bin_name"
        done <<< "$selected"
    fi

    printf '%s\n' "${installed_bins[@]}"
}

# Install full directory (for apps like Firefox that need all files)
install_directory() {
    local extract_dir="$1"
    local app_name="$2"
    local use_sudo="$3"
    local opt_dir="/opt/$app_name"
    local sudo_cmd=""

    [[ "$use_sudo" == "true" ]] && sudo_cmd="sudo"

    log_step "Installing to $opt_dir..."
    $sudo_cmd mkdir -p "$opt_dir"
    $sudo_cmd cp -a "$extract_dir"/. "$opt_dir/"

    # Find main executable and symlink
    local main_bin=""
    if [[ -x "$opt_dir/$app_name" ]]; then
        main_bin="$opt_dir/$app_name"
    else
        main_bin=$(find "$opt_dir" -maxdepth 1 -type f -executable 2>/dev/null | head -1)
    fi

    if [[ -n "$main_bin" ]]; then
        local link_name
        link_name=$(basename "$main_bin")
        $sudo_cmd ln -sf "$main_bin" "$INSTALL_DIR/$link_name"
        log_ok "Symlinked: $INSTALL_DIR/$link_name -> $main_bin"
        echo "$INSTALL_DIR/$link_name"
    fi

    echo "dir:$opt_dir"
}

# Create .desktop file
create_desktop_file() {
    local app_name="$1"
    local exec_path="$2"
    local icon_path="$3"

    mkdir -p "$DESKTOP_DIR"

    local desktop_file="$DESKTOP_DIR/${app_name}.desktop"
    local display_name="${app_name^}"  # Capitalize first letter

    local icon_entry=""
    if [[ -n "$icon_path" ]]; then
        # Copy icon to standard location
        local ext="${icon_path##*.}"
        mkdir -p "$ICON_DIR"
        cp "$icon_path" "$ICON_DIR/${app_name}.${ext}"
        icon_entry="$ICON_DIR/${app_name}.${ext}"
    else
        icon_entry="$app_name"
    fi

    cat > "$desktop_file" <<DESKTOP
[Desktop Entry]
Type=Application
Name=$display_name
Exec=$exec_path
Icon=$icon_entry
Terminal=false
Categories=Utility;
DESKTOP

    chmod +x "$desktop_file"

    # Update desktop database if available
    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
    fi

    log_ok "Created desktop entry: $desktop_file"
    echo "$desktop_file"
}

# Save install registry
save_registry() {
    local app_name="$1"
    local archive="$2"
    shift 2
    local files=("$@")

    ensure_registry

    local reg_file="$REGISTRY_DIR/${app_name}.reg"
    {
        echo "name=$app_name"
        echo "archive=$archive"
        echo "date=$(date -Iseconds)"
        echo "files="
        for f in "${files[@]}"; do
            echo "  $f"
        done
    } > "$reg_file"

    log_ok "Saved to registry: $app_name"
}

# Main install command
cmd_install() {
    local archive=""
    local app_name=""
    local bin_path=""
    local icon_path=""
    local no_desktop=false
    local use_sudo=false
    local full_install=false

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)       app_name="$2"; shift 2 ;;
            --bin-path)   bin_path="$2"; shift 2 ;;
            --icon)       icon_path="$2"; shift 2 ;;
            --no-desktop) no_desktop=true; shift ;;
            --system)     use_sudo=true; shift ;;
            --full)       full_install=true; shift ;;
            -*)           log_err "Unknown option: $1"; exit 1 ;;
            *)
                if [[ -z "$archive" ]]; then
                    archive="$1"
                else
                    log_err "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$archive" ]]; then
        log_err "No archive specified"
        echo "Usage: tax install <archive.tar.xz>"
        exit 1
    fi

    if [[ ! -f "$archive" ]]; then
        log_err "File not found: $archive"
        exit 1
    fi

    # Resolve to absolute path
    archive=$(realpath "$archive")

    # Derive app name from filename if not specified
    if [[ -z "$app_name" ]]; then
        app_name=$(basename "$archive")
        # Strip common suffixes and version patterns
        app_name="${app_name%.tar.*}"
        app_name="${app_name%.txz}"
        app_name="${app_name%.tgz}"
        app_name="${app_name%.tbz2}"
        app_name="${app_name%.tzst}"
        # Strip version numbers like -0.10.0, _v2.1, -linux-x64, etc.
        app_name=$(echo "$app_name" | sed -E 's/[-_]v?[0-9]+\.[0-9]+.*//' | sed -E 's/[-_](linux|x86_64|x64|amd64|aarch64|arm64).*//')
        app_name=$(echo "$app_name" | tr '[:upper:]' '[:lower:]')
    fi

    echo ""
    echo -e "${BOLD}╭─────────────────────────────────────╮${NC}"
    echo -e "${BOLD}│  tax installer v${VERSION}               │${NC}"
    echo -e "${BOLD}╰─────────────────────────────────────╯${NC}"
    echo ""
    log_info "Archive : $(basename "$archive")"
    log_info "App name: $app_name"
    echo ""

    # Check if already installed
    if [[ -f "$REGISTRY_DIR/${app_name}.reg" ]]; then
        log_warn "$app_name is already installed"
        read -rp "  Reinstall? [y/N]: " confirm
        if [[ "$confirm" != [yY] ]]; then
            log_info "Cancelled."
            exit 0
        fi
        cmd_uninstall "$app_name" --quiet
    fi

    # Extract
    local extract_dir
    extract_dir=$(extract_archive "$archive")
    log_ok "Extracted to temp directory"

    # Show contents summary
    local file_count
    file_count=$(find "$extract_dir" -type f 2>/dev/null | wc -l)
    local dir_count
    dir_count=$(find "$extract_dir" -type d 2>/dev/null | wc -l)
    log_info "Contents: $file_count files in $dir_count directories"

    # Detect type
    local detection
    detection=$(detect_app_type "$extract_dir")
    local app_type="${detection%%:*}"
    local app_path="${detection#*:}"

    log_info "Detected type: ${BOLD}$app_type${NC}"
    echo ""

    local installed_files=()

    case "$app_type" in
        appimage)
            local bin_name
            bin_name=$(basename "$app_path")
            local dest="$INSTALL_DIR/${app_name}"
            if [[ "$use_sudo" == "true" ]]; then
                sudo install -Dm755 "$app_path" "$dest"
            else
                install -Dm755 "$app_path" "$dest"
            fi
            installed_files+=("$dest")
            log_ok "Installed AppImage: $dest"
            ;;
        binary)
            if [[ "$full_install" == "true" ]]; then
                local result
                result=$(install_directory "$extract_dir" "$app_name" "$use_sudo")
                while IFS= read -r f; do
                    installed_files+=("$f")
                done <<< "$result"
            else
                local result
                result=$(install_binaries "$extract_dir" "$app_name" "$bin_path" "$use_sudo")
                while IFS= read -r f; do
                    installed_files+=("$f")
                done <<< "$result"
            fi
            ;;
        executable)
            local bin_name
            bin_name=$(basename "$app_path")
            local dest="$INSTALL_DIR/${bin_name}"
            if [[ "$use_sudo" == "true" ]]; then
                sudo install -Dm755 "$app_path" "$dest"
            else
                install -Dm755 "$app_path" "$dest"
            fi
            installed_files+=("$dest")
            log_ok "Installed: $dest"
            ;;
        make|cmake|configure|meson)
            log_warn "Source code detected. This requires compilation."
            echo ""
            echo "  Detected build system: ${BOLD}$app_type${NC}"
            echo ""

            local build_cmd=""
            case "$app_type" in
                make)      build_cmd="make && sudo make install" ;;
                cmake)     build_cmd="mkdir build && cd build && cmake .. && make && sudo make install" ;;
                configure) build_cmd="./configure && make && sudo make install" ;;
                meson)     build_cmd="meson setup build && ninja -C build && sudo ninja -C build install" ;;
            esac

            echo "  Suggested build commands:"
            echo -e "  ${CYAN}cd $extract_dir${NC}"
            echo -e "  ${CYAN}$build_cmd${NC}"
            echo ""
            read -rp "  Run build automatically? [y/N]: " confirm
            if [[ "$confirm" == [yY] ]]; then
                log_step "Building from source..."
                (
                    cd "$extract_dir"
                    eval "$build_cmd"
                )
                log_ok "Build completed"
                installed_files+=("source:$app_type")
            else
                log_info "Skipping build. You can build manually."
                # Keep extracted dir for manual build
                local manual_dir="$HOME/.local/src/$app_name"
                mkdir -p "$(dirname "$manual_dir")"
                cp -a "$extract_dir" "$manual_dir"
                log_info "Source copied to: $manual_dir"
                installed_files+=("src:$manual_dir")
            fi
            ;;
        *)
            log_warn "Could not auto-detect application type."
            echo ""
            echo "  Options:"
            echo "    1) Try to find and install executables"
            echo "    2) Install full directory to /opt/$app_name"
            echo "    3) Cancel"
            echo ""
            read -rp "  Select [1-3]: " choice
            case "$choice" in
                1)
                    local result
                    result=$(install_binaries "$extract_dir" "$app_name" "$bin_path" "$use_sudo")
                    while IFS= read -r f; do
                        installed_files+=("$f")
                    done <<< "$result"
                    ;;
                2)
                    local result
                    result=$(install_directory "$extract_dir" "$app_name" "$use_sudo")
                    while IFS= read -r f; do
                        installed_files+=("$f")
                    done <<< "$result"
                    ;;
                *)
                    log_info "Cancelled."
                    exit 0
                    ;;
            esac
            ;;
    esac

    # Desktop file
    if [[ "$no_desktop" != "true" && "$app_type" != "make" && "$app_type" != "cmake" && "$app_type" != "configure" && "$app_type" != "meson" ]]; then
        echo ""

        # Check for existing .desktop file in archive
        local existing_desktop
        existing_desktop=$(find_desktop_file "$extract_dir")

        if [[ -n "$existing_desktop" ]]; then
            log_info "Found .desktop file in archive"
            mkdir -p "$DESKTOP_DIR"
            cp "$existing_desktop" "$DESKTOP_DIR/${app_name}.desktop"
            chmod +x "$DESKTOP_DIR/${app_name}.desktop"
            installed_files+=("$DESKTOP_DIR/${app_name}.desktop")
            log_ok "Installed desktop entry"
        else
            read -rp "  Create desktop entry? [Y/n]: " create_desktop
            if [[ "$create_desktop" != [nN] ]]; then
                # Find exec path
                local exec_path=""
                for f in "${installed_files[@]}"; do
                    if [[ "$f" == "$INSTALL_DIR/"* && ! "$f" == dir:* ]]; then
                        exec_path="$f"
                        break
                    fi
                done

                # Find icon
                local icon=""
                if [[ -n "$icon_path" ]]; then
                    icon="$extract_dir/$icon_path"
                else
                    icon=$(find_icon "$extract_dir" "$app_name")
                fi

                if [[ -n "$exec_path" ]]; then
                    local desktop_result
                    desktop_result=$(create_desktop_file "$app_name" "$exec_path" "$icon")
                    installed_files+=("$desktop_result")
                fi
            fi
        fi
    fi

    # Save to registry
    save_registry "$app_name" "$(basename "$archive")" "${installed_files[@]}"

    echo ""
    echo -e "${GREEN}${BOLD}Installation complete!${NC}"
    echo ""
    echo -e "  Run with: ${CYAN}$app_name${NC}"
    echo -e "  Remove:   ${CYAN}tax uninstall $app_name${NC}"
    echo ""
}

# List installed apps
cmd_list() {
    ensure_registry

    local regs=("$REGISTRY_DIR"/*.reg)
    if [[ ! -f "${regs[0]}" ]]; then
        log_info "No applications installed via tax."
        return
    fi

    echo ""
    echo -e "${BOLD}Installed applications:${NC}"
    echo ""
    printf "  ${BOLD}%-20s %-30s %s${NC}\n" "NAME" "ARCHIVE" "DATE"
    echo "  $(printf '─%.0s' {1..70})"

    for reg in "${regs[@]}"; do
        local name="" archive="" date=""
        while IFS='=' read -r key val; do
            case "$key" in
                name)    name="$val" ;;
                archive) archive="$val" ;;
                date)    date="${val%%T*}" ;;
            esac
        done < "$reg"
        printf "  %-20s %-30s %s\n" "$name" "$archive" "$date"
    done
    echo ""
}

# Show info about installed app
cmd_info() {
    local app_name="$1"

    if [[ -z "$app_name" ]]; then
        log_err "Specify app name: tax info <name>"
        exit 1
    fi

    local reg_file="$REGISTRY_DIR/${app_name}.reg"
    if [[ ! -f "$reg_file" ]]; then
        log_err "$app_name is not installed via tax"
        exit 1
    fi

    echo ""
    echo -e "${BOLD}Application: $app_name${NC}"
    echo ""

    local in_files=false
    while IFS= read -r line; do
        if [[ "$line" == "files=" ]]; then
            in_files=true
            echo "  Files:"
            continue
        fi
        if $in_files; then
            local f="${line#"  "}"
            if [[ -e "$f" ]]; then
                echo -e "    ${GREEN}✓${NC} $f"
            else
                echo -e "    ${RED}✗${NC} $f (missing)"
            fi
        else
            IFS='=' read -r key val <<< "$line"
            case "$key" in
                name)    echo "  Name   : $val" ;;
                archive) echo "  Archive: $val" ;;
                date)    echo "  Date   : $val" ;;
            esac
        fi
    done < "$reg_file"
    echo ""
}

# Uninstall app
cmd_uninstall() {
    local app_name="$1"
    local quiet=false
    [[ "${2:-}" == "--quiet" ]] && quiet=true

    if [[ -z "$app_name" ]]; then
        log_err "Specify app name: tax uninstall <name>"
        exit 1
    fi

    local reg_file="$REGISTRY_DIR/${app_name}.reg"
    if [[ ! -f "$reg_file" ]]; then
        log_err "$app_name is not installed via tax"
        exit 1
    fi

    if [[ "$quiet" != "true" ]]; then
        echo ""
        log_warn "About to uninstall: $app_name"
        cmd_info "$app_name"
        read -rp "  Confirm uninstall? [y/N]: " confirm
        if [[ "$confirm" != [yY] ]]; then
            log_info "Cancelled."
            exit 0
        fi
    fi

    log_step "Uninstalling $app_name..."

    local in_files=false
    while IFS= read -r line; do
        if [[ "$line" == "files=" ]]; then
            in_files=true
            continue
        fi
        if $in_files; then
            local f="${line#"  "}"

            # Handle dir: prefix (installed directories)
            if [[ "$f" == dir:* ]]; then
                local dir="${f#dir:}"
                if [[ -d "$dir" ]]; then
                    sudo rm -rf "$dir"
                    log_ok "Removed directory: $dir"
                fi
                continue
            fi

            # Handle src: prefix
            if [[ "$f" == src:* ]]; then
                local dir="${f#src:}"
                if [[ -d "$dir" ]]; then
                    rm -rf "$dir"
                    log_ok "Removed source: $dir"
                fi
                continue
            fi

            # Handle source: prefix (build from source)
            if [[ "$f" == source:* ]]; then
                log_warn "Was built from source — may need manual cleanup"
                continue
            fi

            # Regular file
            if [[ -f "$f" ]]; then
                if [[ "$f" == /usr/* || "$f" == /opt/* ]]; then
                    sudo rm -f "$f"
                else
                    rm -f "$f"
                fi
                log_ok "Removed: $f"
            fi
        fi
    done < "$reg_file"

    rm -f "$reg_file"
    log_ok "Removed registry entry"

    if [[ "$quiet" != "true" ]]; then
        echo ""
        echo -e "${GREEN}${BOLD}$app_name uninstalled.${NC}"
        echo ""
    fi
}

# Main
case "${1:-help}" in
    install)   shift; cmd_install "$@" ;;
    list|ls)   cmd_list ;;
    info)      shift; cmd_info "${1:-}" ;;
    uninstall|remove|rm)
               shift; cmd_uninstall "${1:-}" ;;
    help|-h|--help) usage ;;
    version|-v|--version) echo "tax v$VERSION" ;;
    *)
        # If first arg is a file, assume install
        if [[ -f "$1" ]]; then
            cmd_install "$@"
        else
            log_err "Unknown command: $1"
            echo "Run 'tax help' for usage"
            exit 1
        fi
        ;;
esac
